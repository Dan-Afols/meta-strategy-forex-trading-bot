APP_NAME=ForexTradingSystem
APP_ENV=production
DEBUG=false
LOG_LEVEL=INFO

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/trading.db

# MetaTrader 5
MT5_LOGIN=YOUR_MT5_LOGIN
MT5_PASSWORD=YOUR_MT5_PASSWORD
MT5_SERVER=YOUR_MT5_SERVER
MT5_PATH=C:/Program Files/MetaTrader 5/terminal64.exe
MT5_TIMEOUT=10000

# Telegram
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID
TELEGRAM_ENABLED=true

# Dashboard (demo credentials)
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8000
SECRET_KEY=demo-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=1440
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=demo1234

# Trading
TRADING_PAIRS=EURUSD,GBPUSD,USDJPY,AUDUSD,USDCAD,USDCHF,NZDUSD,EURGBP
DEFAULT_TIMEFRAME=M15
MAX_OPEN_TRADES=5
MAX_RISK_PER_TRADE=0.02
MAX_DAILY_LOSS=0.05
ACCOUNT_CURRENCY=USD

# Data
DATA_DIR=./data
CHART_DIR=./data/charts
LOG_DIR=./logs
ML_MODEL_DIR=./ml_models/saved

# Backtesting
BACKTEST_START_DATE=2024-01-01
BACKTEST_END_DATE=2025-12-31

# News Filter
ENABLE_NEWS_FILTER=true
ENABLE_NEWS_EVENTS_UTC=true
NEWS_BLOCK_MINUTES_BEFORE=45
NEWS_BLOCK_MINUTES_AFTER=30
ENABLE_NEWS_AUTO_UPDATE=true
NEWS_EVENTS_URL=https://nfs.faireconomy.media/ff_calendar_thisweek.xml
NEWS_AUTO_REFRESH_MINUTES=360
NEWS_EVENTS_UTC=

# Multi-Timeframe Confirmation
ENABLE_MTF_CONFIRMATION=true
MTF_CONFIRMATION_TIMEFRAME=H4
MTF_CONFIRMATION_MA_PERIOD=50
MTF_CONFIRMATION_STRICT=false

# Automatic Strategy Evolution
ENABLE_STRATEGY_EVOLUTION=true
STRATEGY_EVOLUTION_INTERVAL_CYCLES=12
STRATEGY_EVOLUTION_MIN_TRADES=8
